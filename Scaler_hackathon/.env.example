# Energy Grid OpenEnv — Environment Variables
# Copy this file to .env and fill in your values
# .env is gitignored — never commit your actual keys

# -------------------------------------------------------
# REQUIRED: LLM API key for baseline script
# -------------------------------------------------------

# Groq (recommended — free tier at console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# OpenAI fallback (requires credits)
# OPENAI_API_KEY=your_openai_api_key_here

# -------------------------------------------------------
# OPTIONAL: Override baseline model / endpoint
# -------------------------------------------------------

# BASELINE_MODEL=llama-3.3-70b-versatile
# BASELINE_BASE_URL=https://api.groq.com/openai/v1
